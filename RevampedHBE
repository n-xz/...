local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local StarterGui = game:GetService("StarterGui")

local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local HEAD_SIZE = 6
local CHECK_DELAY = 0.1
local MAX_DISTANCE = 800

local TOGGLE_KEY = Enum.KeyCode.LeftControl

local enabled = false

local originalProps = {}
local espObjects = {}

local rayParams = RaycastParams.new()
rayParams.FilterType = Enum.RaycastFilterType.Blacklist

local function notify(text)
	pcall(function()
		StarterGui:SetCore("SendNotification",{
			Title = "System",
			Text = text,
			Duration = 0.3
		})
	end)
end

local function saveOriginal(hrp)
	if not originalProps[hrp] then
		originalProps[hrp] = {
			Size = hrp.Size,
			Transparency = hrp.Transparency,
			BrickColor = hrp.BrickColor,
			Material = hrp.Material,
			CanCollide = hrp.CanCollide
		}
	end
end

local function restoreOriginal(hrp, player)

	local props = originalProps[hrp]

	if props then
		hrp.Size = props.Size
		hrp.Transparency = props.Transparency
		hrp.BrickColor = props.BrickColor
		hrp.Material = props.Material
		hrp.CanCollide = props.CanCollide
	end

	if espObjects[player] then
		espObjects[player]:Destroy()
		espObjects[player] = nil
	end
end

local function restoreAll()

	for player,highlight in pairs(espObjects) do
		if highlight then
			highlight:Destroy()
		end
	end

	for hrp,props in pairs(originalProps) do
		if hrp then
			hrp.Size = props.Size
			hrp.Transparency = props.Transparency
			hrp.BrickColor = props.BrickColor
			hrp.Material = props.Material
			hrp.CanCollide = props.CanCollide
		end
	end

	espObjects = {}
end

local function applyTo(hrp, player)

	saveOriginal(hrp)

	hrp.Size = Vector3.new(HEAD_SIZE,HEAD_SIZE,HEAD_SIZE)
	hrp.Transparency = .7
	hrp.BrickColor = BrickColor.new("Bright red")
	hrp.Material = Enum.Material.Neon
	hrp.CanCollide = false

	if not espObjects[player] then
		local highlight = Instance.new("Highlight")
		highlight.Adornee = hrp
		highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		highlight.FillTransparency = .7
		highlight.Parent = hrp
		espObjects[player] = highlight
	end
end

local function isVisible(character)

	local head = character:FindFirstChild("Head")
	local hrp = character:FindFirstChild("HumanoidRootPart")

	if not head or not hrp then
		return false
	end

	rayParams.FilterDescendantsInstances = {LocalPlayer.Character}

	local camPos = Camera.CFrame.Position

	local function check(part)

		local direction = part.Position - camPos
		local result = workspace:Raycast(camPos, direction, rayParams)

		if result and result.Instance:IsDescendantOf(character) then
			return true
		end

		return false
	end

	return check(head) or check(hrp)
end

task.spawn(function()

	while true do

		if enabled then

			for _,player in pairs(Players:GetPlayers()) do

				if player ~= LocalPlayer and player.Character then

					if LocalPlayer.Team and player.Team == LocalPlayer.Team then
						continue
					end

					local hrp = player.Character:FindFirstChild("HumanoidRootPart")

					if hrp then

						local distance = (hrp.Position - Camera.CFrame.Position).Magnitude

						if distance < MAX_DISTANCE then

							if isVisible(player.Character) then
								applyTo(hrp,player)
							else
								restoreOriginal(hrp,player)
							end

						end

					end

				end

			end

		end

		task.wait(CHECK_DELAY)

	end

end)

UserInputService.InputBegan:Connect(function(input,gameProcessed)

	if gameProcessed then return end

	if input.KeyCode == TOGGLE_KEY then

		enabled = not enabled

		if enabled then
			notify("e")
		else
			notify("d")
			restoreAll()
		end

	end

end)

local function setupDeath()

	local character = LocalPlayer.Character
	if not character then return end

	local humanoid = character:FindFirstChildOfClass("Humanoid")

	if humanoid then
		humanoid.Died:Connect(function()
			enabled = false
			restoreAll()
			notify("d")
		end)
	end

end

if LocalPlayer.Character then
	setupDeath()
end

LocalPlayer.CharacterAdded:Connect(function()
	task.wait(1)
	setupDeath()
end)
